{
  "name": "crgbaumgarts-websites",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for crgbaumgart's  personal websites",
  "scripts": {
    "dev:dbc": "pnpm --filter denton-bights-collective dev",
    "dev:cctx": "pnpm --filter craigs-creations dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}
